# ======================
# Busca CRECI - Environment Variables
# ======================
# Copy this file to .env and fill in your values

# Application
APP_DEBUG=true

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=buscacreci
DB_USERNAME=buscacreci
DB_PASSWORD=buscacreci_secret

# Redis
REDIS_SCHEME=tcp
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ (Event Bus)
EVENT_BUS_HOST=rabbitmq-master
EVENT_BUS_PORT=5672
EVENT_BUS_USER=guest
EVENT_BUS_PASSWORD=guest
EVENT_BUS_MAX_RETRY_CONNECTIONS=10
EVENT_BUS_RETRY_CONNECTIONS_DELAY_SECONDS=5

# 2Captcha (optional - only needed for states that require CAPTCHA solving)
CAPTCHA_TOKEN_2CAPTCHA=your_2captcha_api_key_here
