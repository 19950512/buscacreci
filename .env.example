# ======================
# Busca CRECI - Environment Variables
# ======================
# Copy this file to .env and fill in your values

# Application
APP_DEBUG=false

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_strong_password_here

# Redis
REDIS_SCHEME=tcp
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# RabbitMQ (Event Bus)
EVENT_BUS_HOST=rabbitmq-master
EVENT_BUS_PORT=5672
EVENT_BUS_USER=your_rabbitmq_user
EVENT_BUS_PASSWORD=your_rabbitmq_password
EVENT_BUS_MAX_RETRY_CONNECTIONS=10
EVENT_BUS_RETRY_CONNECTIONS_DELAY_SECONDS=5

# 2Captcha (optional - only needed for states that require CAPTCHA solving)
CAPTCHA_TOKEN_2CAPTCHA=your_2captcha_api_key_here
